{
  "name": "hira-disease-mcp",
  "version": "0.1.0",
  "description": "Remote MCP server for HIRA disease information service, designed for Claude custom connectors.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "hira-disease-mcp": "dist/src/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts --mode http --port 3000",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hira",
    "healthcare",
